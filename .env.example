# Build-time public environment variables (safe to expose in the client bundle).
# Copy to `.env` for local overrides. Only VITE_-prefixed vars reach the frontend.
# Do NOT put secrets here — see .dev.vars.example for server-side secrets.

VITE_APP_NAME="Atlase"
VITE_CURRENCY="PHP"
VITE_LOCALE="en-PH"

# Where the client sends API requests. Empty = same origin (recommended).
VITE_API_BASE_URL=""
